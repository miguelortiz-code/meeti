<main class="contenedor panel-administracion">
    <h1> <%= namePage%> </h1>
    <div class="contenedor-botones">
        <a href="/groups/new-group" class="btn btn-amarillo">Nuevo Grupo</a>
        <a href="/new-meeti" class="btn btn-azul">Nuevo Meeti</a>
        <a href="/profile" class="btn btn-rosa">Editar Perfil</a>
        <a href="/image" class="btn btn-amarillo">Imagen Perfil</a>
    </div>

    <div class="seccion-admin">
        <h2>Tus Meeti's</h2>
        <ul>
            <li>
                <div class="informacion-admin">
                    <p class="fecha">Lunes, 22 de mayo de 2019</p>
                    <h3>E-Commerce en México</h3>
                    <small>23 Personas Asistiran</small>
                </div>

                <div class="acciones contenedor-botones">
                    <a href="#" class="btn btn-verde">Editar</a>
                    <a href="#" class="btn btn-azul2">Asistentes</a>
                    <a href="#" class="btn btn-rojo">Eliminar</a>
                </div>
            </li>

            <li>
                <div class="informacion-admin">
                    <p class="fecha">Miércoles, 24 de mayo de 2019</p>
                    <h3>Bitcoin y otras cripto monedas</h3>
                    <small>30 Personas Asistiran</small>
                </div>

                <div class="acciones contenedor-botones">
                    <a href="#" class="btn btn-verde">Editar</a>
                    <a href="#" class="btn btn-azul2">Asistentes</a>
                    <a href="#" class="btn btn-rojo">Eliminar</a>
                </div>
            </li>

            <li>
                <div class="informacion-admin">
                    <p class="fecha">Viernes, 26 de mayo de 2019</p>
                    <h3>Node Colombia</h3>
                    <small>100 Personas Asistiran</small>
                </div>

                <div class="acciones contenedor-botones">
                    <a href="#" class="btn btn-verde">Editar</a>
                    <a href="#" class="btn btn-azul2">Asistentes</a>
                    <a href="#" class="btn btn-rojo">Eliminar</a>
                </div>
            </li>
        </ul>
    </div>

    <div class="seccion-admin">
        <h2>Tus Grupos </h2>
        <% if(groups.length){%>
            <ul>
                <% groups.forEach(group => { %>
                <li>
                    <div class="informacion-admin">
                        <h3><%= group.name%></h3>
                    </div>

                    <div class="acciones contenedor-botones">
                        <a href="/groups/edit-group/<%= group.code%>" class="btn btn-verde">Editar</a>
                        <a href="/groups/image-group/<%= group.code%>" class="btn btn-azul2">Imagen</a>
                        <a href="/groups/delete/<%= group.code%>" class="btn btn-rojo">Eliminar</a>
                    </div>
                </li>
            <% }); %>
            </ul>
        <%} else{%>
            <p>No tienes grupos creados.</p>
        <%}%>
    </div>
</main>