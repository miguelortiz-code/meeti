<main class="contenedor contenedor-formularios no-padding">
    <h1> <%=namePage %> </h1>
    <form action="/new-group" method="POST" class="default-form">
        <div class="campo">
            <label for="name">Nombre</label>
            <input type="text" name="name" id="name" placeholder="Nombre Grupo">
        </div>

        <div class="campo descripcion">
            <label for="description">Descripción</label>
            <div class="contenedor-editor">
                <input type="hidden" id="x" name="description">
               <trix-editor input="x"></trix-editor>
            </div>
        </div>

        <div class="campo">
            <label for="category">Categoria</label>
            <select name="category" id="category">
                <option value="" selected disabled>Selecciona una categoria</option>
            </select>
        </div>
        
        <div class="campo">
            <label for="image">Imagen</label>
            <input type="file" name="image" id="image">
        </div>

        <div class="campo">
            <label for="url">Sitio Web</label>
            <input type="url" name="url" id="url" placeholder="https://www.google.com">
        </div>

        <div class="campo enviar">
            <input type="submit" value="Crear" class="btn btn-rosa">
        </div>
    </form>
</main>
