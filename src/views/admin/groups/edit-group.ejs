<main class="contenedor contenedor-formularios no-padding">
    <h1> <%=namePage %> </h1>
    <form method="POST" enctype="multipart/form-data" class="default-form">
        <div class="campo">
            <label for="name">Nombre</label>
            <input type="text" name="name" id="name" placeholder="Nombre Grupo" value="<%= group.name%>">
        </div>

        <div class="campo descripcion">
            <label for="description">Descripción</label>
            <div class="contenedor-editor">
                <input type="hidden" id="x" name="description" value="<%= group.description%>">
                <trix-editor input="x"></trix-editor>
            </div>
        </div>

        <div class="campo">
            <label for="category">Categoria</label>
            <select name="category" id="category">
                <option value="" disabled <%= !group?.category ? "selected" : "" %>>Selecciona una categoria</option>
                 <% categories.forEach(category => { %>
                <option value="<%= category.id %>" <%= (group.id_category === category.id) ? "selected" : "" %>>
                    <%= category.category %>
                </option>
                <% }) %>
            </select>
        </div>

        <div class="campo">
            <label for="url">Sitio Web</label>
            <input type="url" name="url" id="url" placeholder="https://www.google.com" value="<%= group.url%>">
        </div>

        <div class="campo enviar">
            <input type="submit" value="Editar grupo" class="btn btn-rosa">
        </div>
    </form>
</main>