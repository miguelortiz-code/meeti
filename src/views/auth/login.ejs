<main class="contenedor contenedor-formularios ">
    <h1> <%= namePage %>  </h1>
    <form action="/login" method="POST" class="default-form">

        <div class="campo">
            <label for="email">Correo Electrónico:</label>
            <input type="email" name="email" id="email" placeholder="johnDoe@gmail.com" value="<%= user ? user.email : '' %>" >
        </div>

        <div class="campo">
            <label for="password">Contraseña:</label>
            <input type="password" name="password" id="password" placeholder="**********">
        </div>

        <div class="campo enviar">
            <input type="submit" value="Iniciar sesión" class="btn btn-rosa">
        </div>
    </form>
</main>